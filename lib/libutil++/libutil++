#ifndef __LIBUTILPP__
#define	__LIBUTILPP__

#include <sys/cdefs.h>
#include <netdb.h>

#include <memory>

namespace freebsd {
	std::string stringf(const char *fmt, ...) __printflike(1, 2);

	struct file_closer
	{
		void operator() (FILE *fp) const
		{
			fclose(fp);
		}
	};

	typedef std::unique_ptr<FILE, file_closer> FILE_up;

	/*
	 * A unique_ptr<> wrapper intended to be used with the result
	 * of getaddrinfo(3).  The deleter calls freeaddrinfo() when
	 * the object is destroyed.
	 */
	struct freeaddrinfo_deleter
	{
		void operator() (struct addrinfo *ai) const
		{
			freeaddrinfo(ai);
		}
	};

	typedef std::unique_ptr<addrinfo, freeaddrinfo_deleter> addrinfo_up;

	template <class T>
	struct free_deleter
	{
		void operator() (T *p) const
		{
			free(p);
		}
	};

	template <class T>
	using malloc_up = std::unique_ptr<T, free_deleter<T>>;
}

#endif /* !__LIBUTILPP__ */
